{
  "name": "creditflow-core",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "pnpm --filter @creditflow-core/api dev",
    "dev:worker": "pnpm --filter @creditflow-core/worker dev",
    "dev": "pnpm dev:api",
    "lint": "echo 'Add eslint if needed'",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "tsx": "^4.19.2"
  }
}
