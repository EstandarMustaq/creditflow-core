{
  "name": "creditflow-core",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "CoreBank",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "pnpm --filter @creditflow-core/api dev",
    "dev:corebank": "pnpm --filter corebank-dashboard dev",
    "dev:worker": "pnpm --filter @creditflow-core/worker dev",
    "dev": "pnpm dev:api",
    "lint": "echo 'Add eslint if needed'",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  }
}
